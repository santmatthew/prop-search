# Copy this file to .env and fill in your keys. .env is gitignored.

# Apify token (https://console.apify.com/account/integrations) — free trial credit.
APIFY_TOKEN=

# Google Maps API key with BOTH "Routes API" and "Geocoding API" enabled.
GOOGLE_MAPS_API_KEY=

# Optional: override the Apify actor used for scraping.
# APIFY_ACTOR=makework36/idealista-scraper

# Not required for the current (third-party API) approach — kept only for a
# possible future login-based scraping path.
IDEALISTA_EMAIL=matt@cobusho.com
IDEALISTA_PASSWORD=
