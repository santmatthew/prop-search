# Copy this file to .env and fill in your keys. .env is gitignored.

# Apify token (https://console.apify.com/account/integrations).
# Needed for the idealista and fotocasa sources. (redpiso uses its own free API.)
APIFY_TOKEN=

# Google Maps API key with "Routes API" enabled (Geocoding uses free Nominatim).
# Needed only for the transit-time step.
GOOGLE_MAPS_API_KEY=

# Optional: override the per-source Apify actors.
# IDEALISTA_ACTOR=dz_omar/idealista-scraper-api
# FOTOCASA_ACTOR=azzouzana/fotocasa-es-search-results-scraper-by-search-url-ppr
